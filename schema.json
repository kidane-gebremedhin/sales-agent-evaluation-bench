{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "tenacious_bench_v0.1",
  "version": "0.1.0",
  "license": "CC-BY-4.0",
  "generated_at_utc": "2026-04-29",
  "description": "Tenacious-Bench v0.1 — task schema and three example tasks. Every task is machine-verifiable: scoring_evaluator.py reads (task, candidate_output) and returns a numerical score with no human in the loop.",

  "rubric_dimensions": [
    {
      "id": "segment_reasoning",
      "covers_probes": ["P-0001", "P-0002", "P-0003", "P-0004", "P-0005"],
      "scale": "binary_with_partial",
      "description": "Did the agent classify the prospect into the correct segment given conflicting signals (layoff+funding, interim CTO, AI-maturity gate, abstain threshold)? Compared to ground-truth label."
    },
    {
      "id": "signal_grounding",
      "covers_probes": ["P-0101", "P-0102", "P-0103", "P-0801", "P-0802", "P-0803", "P-0901"],
      "scale": "deterministic_pass_fail_plus_judge_1_5",
      "description": "Every quantitative claim in the body resolves to a source_url or a brief field. No 'aggressive hiring' on <5 open roles. No funding amount quoted without source. Peer evidence has source URLs."
    },
    {
      "id": "bench_honesty",
      "covers_probes": ["P-0201", "P-0202", "P-0203"],
      "scale": "deterministic_with_handoff_branch",
      "description": "If the prospect's stated need exceeds the bench_summary count for the required stack, the body either (a) proposes a phased ramp with explicit capacity gate, or (b) flags the mismatch and routes to handoff. Committing to capacity the bench does not show fails the dimension."
    },
    {
      "id": "tone_preservation",
      "covers_probes": ["P-0301", "P-0302", "P-0303", "P-1101", "P-1102"],
      "scale": "five_markers_judge_1_5",
      "description": "Score 1–5 on each of the five Tenacious markers (direct, grounded, honest, professional, non-condescending). Pass = no marker below 4/5. Deterministic checks for the disallowed-phrase set still apply."
    },
    {
      "id": "gap_framing",
      "covers_probes": ["P-0902", "P-0903"],
      "scale": "judge_1_5",
      "description": "Segment 4 outreach frames the gap as a research finding or a question worth asking, not as a failure of the prospect's leadership. Judge scores condescension level on 1–5; pass = condescension ≤ 2."
    }
  ],

  "task_object_schema": {
    "type": "object",
    "required": [
      "task_id",
      "primary_dimension",
      "difficulty",
      "source_mode",
      "task_type",
      "input",
      "rubric"
    ],
    "properties": {
      "task_id":          { "type": "string", "pattern": "^TB-[0-9]{4}$" },
      "primary_dimension":{ "type": "string", "enum": ["segment_reasoning", "signal_grounding", "bench_honesty", "tone_preservation", "gap_framing"] },
      "secondary_dimensions": { "type": "array", "items": { "type": "string" } },
      "difficulty":       { "type": "string", "enum": ["easy", "medium", "hard", "adversarial"] },
      "source_mode":      { "type": "string", "enum": ["trace_derived", "programmatic", "multi_llm_synthesis", "hand_authored"] },
      "source_provenance":{ "type": "object", "description": "Per Magpie/Source2Synth pattern. Records generator model, judge model, judge score, originating Week 10 trace ID where applicable, dedup hash." },
      "task_type":        { "type": "string", "enum": ["classify_segment", "compose_cold_1", "compose_warm_reply", "compose_warm_objection", "scheduling_offer", "reengagement"] },
      "input": {
        "type": "object",
        "properties": {
          "hiring_signal_brief": { "type": "object" },
          "competitor_gap_brief": { "type": ["object", "null"] },
          "bench_summary": { "type": "object" },
          "prior_thread": { "type": ["array", "null"], "items": { "type": "object" } },
          "prospect_meta": { "type": "object", "description": "Domain, persona, timezone, contact_id." }
        }
      },
      "ground_truth": { "type": "object", "description": "Where applicable (segment classification, expected handoff branch). Null for open-ended generation tasks scored by rubric only." },
      "rubric": {
        "type": "object",
        "properties": {
          "deterministic_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "predicate"],
              "properties": {
                "name": { "type": "string" },
                "predicate": { "type": "string", "description": "Identifier resolved by scoring_evaluator.py: e.g., regex_absent, regex_present, max_word_count, source_url_for_each_quant_claim, bench_capacity_not_overcommitted, calendar_link_present, segment_label_matches_ground_truth." },
                "args": { "type": "object" },
                "weight": { "type": "number" }
              }
            }
          },
          "judge_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "marker", "min_score"],
              "properties": {
                "name": { "type": "string" },
                "marker": { "type": "string", "enum": ["direct", "grounded", "honest", "professional", "non_condescending", "research_framed"] },
                "min_score": { "type": "integer", "minimum": 1, "maximum": 5 },
                "weight": { "type": "number" }
              }
            }
          },
          "passing_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "Total weighted score >= passing_score → task passes." }
        }
      }
    }
  },

